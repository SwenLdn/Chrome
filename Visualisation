<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>0x-MODE Visual Search Extractor</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .pixel-grid {
            display: grid;
            grid-template-columns: repeat(8, 1fr);
            gap: 2px;
        }
        .pixel-cell {
            aspect-ratio: 1;
            border-radius: 2px;
            transition: all 0.2s;
            cursor: crosshair;
        }
        .pixel-cell:hover {
            transform: scale(1.1);
            z-index: 10;
            box-shadow: 0 0 10px rgba(255,255,255,0.5);
        }
        .terminal {
            background: #0a0a0a;
            font-family: 'Courier New', monospace;
        }
    </style>
</head>
<body class="bg-zinc-900 text-zinc-100 min-h-screen p-4 md:p-8">
    <div class="max-w-6xl mx-auto">
        <header class="mb-8 border-b border-zinc-700 pb-4">
            <h1 class="text-3xl font-bold text-blue-400">0x-MODE: Bytecode Bridge</h1>
            <p class="text-zinc-400">System: ARM-64 Native | Mode: <span class="text-green-500">100X Throughput</span> | User: 501</p>
        </header>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            <!-- Visual Search Area (Ta Component) -->
            <div class="bg-zinc-800 p-6 rounded-xl border border-zinc-700">
                <h2 class="text-xl mb-4 flex items-center">
                    <span class="w-3 h-3 bg-red-500 rounded-full mr-2 animate-pulse"></span>
                    [Ta] Visual Search Input (Canvas)
                </h2>
                <div id="pixelGrid" class="pixel-grid bg-zinc-900 p-2 rounded border border-zinc-600">
                    <!-- Pixels generated via JS -->
                </div>
                <div class="mt-6 flex gap-4">
                    <button onclick="generateNoise()" class="bg-blue-600 hover:bg-blue-500 px-4 py-2 rounded font-bold transition">New Buffer</button>
                    <button onclick="extractAll()" class="bg-green-600 hover:bg-green-500 px-4 py-2 rounded font-bold transition">Extract 0x Payload</button>
                </div>
            </div>

            <!-- Bytecode Terminal (Oa Component) -->
            <div class="terminal p-6 rounded-xl border border-zinc-700 h-[500px] flex flex-col">
                <h2 class="text-xl mb-4 text-green-400 font-mono">[Oa] Bytecode Terminal</h2>
                <div id="logOutput" class="flex-grow overflow-y-auto text-sm font-mono space-y-1 text-green-500 custom-scrollbar">
                    <div>> Initializing KHTML/Gecko Bridge...</div>
                    <div>> 0x-MODE active. Ready for 100X stream.</div>
                </div>
            </div>
        </div>
    </div>

    <script>
        const logOutput = document.getElementById('logOutput');
        const pixelGrid = document.getElementById('pixelGrid');

        // Hex-Pool mit versteckten Payloads (Sso, ARM, 0x, etc)
        const payloadPool = ["53736f", "41524d", "30784d", "2c2d2e", "f4b5d3", "fb5d3a", "23469a", "e14012"];

        function log(msg, color = "text-green-500") {
            const div = document.createElement('div');
            div.className = color;
            div.innerHTML = `> ${msg}`;
            logOutput.appendChild(div);
            logOutput.scrollTop = logOutput.scrollHeight;
        }

        function generateNoise() {
            pixelGrid.innerHTML = '';
            for (let i = 0; i < 64; i++) {
                const hex = payloadPool[Math.floor(Math.random() * payloadPool.length)];
                const cell = document.createElement('div');
                cell.className = 'pixel-cell';
                cell.style.backgroundColor = `#${hex}`;
                cell.title = `#${hex}`;
                cell.onclick = () => extractPixel(hex);
                pixelGrid.appendChild(cell);
            }
            log("New Memory Buffer loaded into Canvas.", "text-blue-400");
        }

        function hexToAscii(hex) {
            let str = '';
            for (let n = 0; n < hex.length; n += 2) {
                str += String.fromCharCode(parseInt(hex.substr(n, 2), 16));
            }
            return str;
        }

        function extractPixel(hex) {
            const ascii = hexToAscii(hex);
            log(`EXTRACT: #${hex} -> ASCII: '${ascii}' | 0x-Shift: Active`, "text-yellow-400");
        }

        function extractAll() {
            log("STARTING FULL SCAN (100X)...", "text-white font-bold");
            const cells = document.querySelectorAll('.pixel-cell');
            let fullString = "";
            cells.forEach((cell, i) => {
                const hex = cell.title.replace('#', '');
                fullString += hexToAscii(hex);
                if (i % 8 === 7) {
                    log(`Row ${Math.floor(i/8)}: Byte-Stream Sync [OK]`, "text-zinc-500");
                }
            });
            log(`RECONSTRUCTED PAYLOAD: ${fullString.substring(0, 32)}...`, "text-green-400 font-bold");
            log(`Memory Address Mapping: IEC61966-2.1 verified.`, "text-blue-400");
        }

        window.onload = generateNoise;
    </script>
</body>
</html>
